" Theme
colorscheme koehler
syntax on

" Line numbers
set number
set relativenumber

" Indentation
set autoindent
set smartindent
set expandtab
set shiftwidth=2
set tabstop=2

" Search
set hlsearch
set incsearch
set ignorecase
set smartcase

" Editor behaviour
set nowrap
set scrolloff=8
set backspace=indent,eol,start
set noswapfile
set encoding=utf-8

" UI
set ruler
set showcmd
set wildmenu
set laststatus=2
